---
import { trabajos } from "../data/negocio";
---

<section id="trabajos" class="trabajos">
  <div class="contenedor">
    <p class="eyebrow">Resultados reales</p>
    <h2 class="trabajos-titulo">Antes y después</h2>
    <p class="trabajos-sub">
      Cada imagen muestra el trabajo real de nuestro equipo. Del deterioro al
      acabado perfecto.
    </p>

    <div class="trabajos-grid">
      {
        trabajos.map((t) => (
          <div class="trabajo-card">
            <div class="comparacion">
              <!-- Imagen ANTES -->
              <div class="lado lado-antes">
                <div class="placeholder-img">
                  <span class="placeholder-icono">📷</span>
                  <span class="placeholder-texto">
                    ANTES — Sustituir por foto real
                  </span>
                </div>
                <span class="etiqueta etiqueta-antes">ANTES</span>
              </div>
              <!-- Divisor central -->
              <div class="divisor" aria-hidden="true">
                <div class="divisor-linea"></div>
                <div class="divisor-circulo">↔</div>
              </div>
              <!-- Imagen DESPUÉS -->
              <div class="lado lado-despues">
                <div class="placeholder-img placeholder-despues">
                  <span class="placeholder-icono">✨</span>
                  <span class="placeholder-texto">
                    DESPUÉS — Sustituir por foto real
                  </span>
                </div>
                <span class="etiqueta etiqueta-despues">DESPUÉS</span>
              </div>
            </div>
            <div class="trabajo-info">
              <h3>{t.titulo}</h3>
              <p>{t.descripcion}</p>
            </div>
          </div>
        ))
      }
    </div>

    <p class="aviso-placeholder">
      ⚠️ Las imágenes de esta sección son marcadores de posición. Por favor,
      sustituye cada par con fotos reales de trabajos realizados en el taller.
    </p>
  </div>
</section>

<style>
  .trabajos {
    background: var(--gris-claro);
  }

  .trabajos-titulo {
    font-size: clamp(2rem, 6vw, 3rem);
    color: var(--azul);
    margin: 0.75rem 0 1rem;
  }

  .trabajos-sub {
    font-size: 1.05rem;
    color: var(--gris-texto);
    max-width: 48ch;
    margin-bottom: 3rem;
  }

  .trabajos-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .trabajos-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .trabajo-card {
    background: var(--blanco);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--gris-borde);
    box-shadow: 0 2px 12px rgba(26, 43, 92, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .trabajo-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(26, 43, 92, 0.12);
  }

  .comparacion {
    position: relative;
    display: flex;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .lado {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .placeholder-img {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #e8edf5 0%, #d5ddef 100%);
    text-align: center;
    padding: 1rem;
  }

  .placeholder-despues {
    background: linear-gradient(135deg, #eaf5ea 0%, #c8e6c9 100%);
  }

  .placeholder-icono {
    font-size: 2rem;
    display: block;
  }

  .placeholder-texto {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--gris-texto);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.3;
  }

  /* Etiquetas ANTES / DESPUÉS */
  .etiqueta {
    position: absolute;
    top: 0.75rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .etiqueta-antes {
    left: 0.75rem;
    background: var(--rojo);
    color: var(--blanco);
  }

  .etiqueta-despues {
    right: 0.75rem;
    background: #2e7d32;
    color: var(--blanco);
  }

  /* Divisor central */
  .divisor {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
    pointer-events: none;
  }

  .divisor-linea {
    width: 2px;
    flex: 1;
    background: var(--blanco);
    opacity: 0.9;
  }

  .divisor-circulo {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--blanco);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--azul);
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  /* Info debajo */
  .trabajo-info {
    padding: 1.25rem 1.5rem;
  }

  .trabajo-info h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--azul);
    margin-bottom: 0.3rem;
  }

  .trabajo-info p {
    font-size: 0.9rem;
    color: var(--gris-texto);
  }

  /* Aviso para el gestor del sitio */
  .aviso-placeholder {
    margin-top: 2.5rem;
    padding: 1rem 1.5rem;
    background: #fff8e1;
    border: 2px dashed var(--amarillo-oscuro);
    border-radius: 8px;
    font-size: 0.9rem;
    color: #6d5400;
    font-weight: 500;
    text-align: center;
  }
</style>
