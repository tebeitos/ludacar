---
import { negocio } from "../data/negocio";
---

<section id="contacto" class="ubicacion">
  <div class="contenedor ubicacion-grid">
    <div class="ubicacion-info">
      <p class="eyebrow-claro">Dónde estamos</p>
      <h2 class="ubicacion-titulo">Visítanos en Gijón</h2>

      <ul class="ubicacion-datos">
        <li>
          <span class="dato-icono">📍</span>
          <div>
            <strong>Dirección</strong>
            <span>{negocio.direccion}</span>
            <span>{negocio.codigoPostal} {negocio.ciudad}</span>
          </div>
        </li>
        <li>
          <span class="dato-icono" style="color: var(--amarillo); display: inline-flex; align-items: center; margin-top: 0.25rem;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-2.2 2.2a15.045 15.045 0 0 1-6.59-6.59l2.2-2.2c.28-.28.36-.67.25-1.02A11.36 11.36 0 0 0 8.5 4c0-.55-.45-1-1-1H4.01c-.55 0-1 .45-1 1 0 9.39 7.61 17 17 17 .55 0 1-.45 1-1v-3.59c0-.55-.45-1-1-1z"/>
            </svg>
          </span>
          <div>
            <strong>Teléfono</strong>
            <a href={`tel:${negocio.telefonoLink}`}>{negocio.telefono}</a>
          </div>
        </li>
        <li>
          <span class="dato-icono">🕐</span>
          <div>
            <strong>Horario</strong>
            <span>{negocio.horario}</span>
          </div>
        </li>
      </ul>

      <div class="ubicacion-botones">
        <a class="boton boton-secundario" href={`tel:${negocio.telefonoLink}`}
          >📞 Llamar</a
        >
        <a
          class="boton boton-primario"
          href={`https://wa.me/${negocio.whatsapp}?text=${encodeURIComponent("Hola, quería pedir un presupuesto")}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          💬 WhatsApp
        </a>
      </div>
    </div>

    <div class="ubicacion-mapa">
      <iframe
        src={negocio.mapsEmbedSrc}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Mapa de ${negocio.nombre}`}
      ></iframe>
    </div>
  </div>
</section>

<style>
  .ubicacion {
    background: var(--azul);
    color: var(--blanco);
  }

  .ubicacion-grid {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 800px) {
    .ubicacion-grid {
      grid-template-columns: 1fr 1.2fr;
      align-items: center;
    }
  }

  .ubicacion-titulo {
    font-size: clamp(2rem, 5.5vw, 3rem);
    color: var(--blanco);
    margin: 0.75rem 0 2rem;
  }

  .ubicacion-datos {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ubicacion-datos li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .dato-icono {
    font-size: 1.4rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .ubicacion-datos div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ubicacion-datos strong {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--amarillo);
    font-weight: 700;
  }

  .ubicacion-datos span,
  .ubicacion-datos a {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    line-height: 1.4;
  }

  .ubicacion-datos a {
    color: var(--amarillo);
    font-weight: 600;
  }

  .ubicacion-datos a:hover {
    text-decoration: underline;
  }

  .ubicacion-botones {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ubicacion-mapa {
    border-radius: 16px;
    overflow: hidden;
    border: 3px solid rgba(245, 197, 24, 0.25);
    aspect-ratio: 4 / 3;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .ubicacion-mapa iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
