---
import { negocio } from "../data/negocio";
---

<a
  class="wa-flotante"
  href={`https://wa.me/${negocio.whatsapp}?text=${encodeURIComponent("Hola, quería pedir un presupuesto de chapa y pintura")}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribir por WhatsApp"
>
  <span aria-hidden="true">💬</span>
</a>

<style>
  .wa-flotante {
    position: fixed;
    bottom: 50px;
    right: 1.25rem;
    z-index: 40;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amarillo);
    color: var(--azul);
    border: 3px solid var(--azul);
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(26, 43, 92, 0.3);
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .wa-flotante:hover {
    transform: scale(1.08);
  }

  .wa-flotante:active {
    transform: scale(0.95);
  }

  .wa-flotante span {
    font-size: 1.6rem;
    line-height: 1;
  }

  @media (min-width: 768px) {
    .wa-flotante {
      bottom: 1.25rem;
    }
  }
</style>
