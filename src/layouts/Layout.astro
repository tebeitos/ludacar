---
import { negocio } from "../data/negocio";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ludacar — Taller de Chapa y Pintura en Gijón",
  description = "Taller de chapa y pintura del automóvil en Gijón. Restauración de chapa, sustitución de lunas, restauración de faros y pulido de carrocería. Valoración 5,0/5 en Google.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="chapa y pintura Gijón, taller carrocería Gijón, reparación chapa Gijón, sustitución lunas Gijón, pulido carrocería Asturias, Ludacar" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="business.business" />
    <meta property="og:locale" content="es_ES" />

    <!-- Fuente: Inter (cuerpo) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org: AutoRepair -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AutoRepair",
      "name": negocio.nombre,
      "description": "Taller de chapa y pintura del automóvil en Gijón. Restauración de chapa, sustitución de lunas, restauración de faros y pulido de carrocería.",
      "image": "",
      "telephone": negocio.telefono,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": negocio.direccion,
        "addressLocality": negocio.ciudad,
        "postalCode": negocio.codigoPostal,
        "addressRegion": "Asturias",
        "addressCountry": "ES",
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": negocio.rating.replace(",", "."),
        "reviewCount": negocio.numResenas,
        "bestRating": "5",
      },
      "url": "https://ludacar.es",
    })} />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --azul: #1a2b5c;
    --azul-oscuro: #111c3e;
    --azul-medio: #253676;
    --amarillo: #f5c518;
    --amarillo-oscuro: #d9ac00;
    --rojo: #d62828;
    --rojo-oscuro: #b82020;
    --blanco: #ffffff;
    --gris-claro: #f4f6fb;
    --gris-texto: #4a4f68;
    --gris-borde: #dde2f0;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Compensa la altura del header sticky al pulsar en enlaces de anclaje */
  [id] {
    scroll-margin-top: 75px; /* Ajuste a 75px en móvil */
  }

  @media (min-width: 768px) {
    [id] {
      scroll-margin-top: 90px; /* Ajuste a 90px en ordenador */
    }
  }

  body {
    margin: 0;
    font-family: "Inter", sans-serif;
    color: var(--azul);
    background: var(--blanco);
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3 {
    font-family: "Inter", sans-serif;
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
  }

  p {
    margin: 0;
    line-height: 1.6;
  }

  a {
    color: inherit;
  }

  img {
    max-width: 100%;
    display: block;
  }

  section {
    padding: 4rem 1.5rem;
  }

  @media (min-width: 768px) {
    section {
      padding: 6rem 3rem;
    }
  }

  .contenedor {
    max-width: 1080px;
    margin: 0 auto;
  }

  .boton {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    text-decoration: none;
    padding: 0.9rem 1.75rem;
    border-radius: 999px;
    border: 2px solid transparent;
    transition:
      transform 0.15s ease,
      background 0.15s ease,
      box-shadow 0.15s ease;
    font-size: 1rem;
    cursor: pointer;
  }

  .boton:active {
    transform: scale(0.97);
  }

  .boton-primario {
    background: var(--rojo);
    color: var(--blanco);
    border-color: var(--rojo);
  }

  .boton-primario:hover {
    background: var(--rojo-oscuro);
    border-color: var(--rojo-oscuro);
    box-shadow: 0 4px 16px rgba(214, 40, 40, 0.35);
  }

  .boton-secundario {
    background: var(--amarillo);
    color: var(--azul);
    border-color: var(--amarillo);
  }

  .boton-secundario:hover {
    background: var(--amarillo-oscuro);
    border-color: var(--amarillo-oscuro);
    box-shadow: 0 4px 16px rgba(245, 197, 24, 0.4);
  }

  .boton-borde {
    background: transparent;
    color: var(--blanco);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .boton-borde:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--blanco);
  }

  .eyebrow {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.8rem;
    color: var(--amarillo-oscuro);
  }

  .eyebrow-claro {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.8rem;
    color: var(--amarillo);
  }
</style>
